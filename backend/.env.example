# Application
APP_NAME=QA Document Intelligence Platform
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///database/qa.db
POSTGRES_URL=postgresql://user:password@localhost/qa_db

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=200000000

# CORS
# JSON array string is supported by backend/config.py
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://app.yourdomain.com"]

# Security
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
TOKEN_EXPIRY=3600

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_UPLOAD_PER_MINUTE=5/minute
RATE_LIMIT_DEFAULT_PER_HOUR=50/hour
RATE_LIMIT_DEFAULT_PER_DAY=200/day

